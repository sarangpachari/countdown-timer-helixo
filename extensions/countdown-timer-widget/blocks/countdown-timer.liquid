{% comment %}
  Countdown Timer — Theme App Extension Block
  Preact-powered widget fetching active timer from Node API.
{% endcomment %}

<div
  id="countdown-timer-widget-root"
  data-shop="{{ shop.permanent_domain }}"
  data-position="{{ block.settings.position }}"
  data-api-url="{{ block.settings.api_base_url }}"
></div>

{{ 'countdown-timer.css' | asset_url | stylesheet_tag }}

{%- comment -%} Load Preact UMD first, then our Preact-based widget {%- endcomment -%}
<script src="https://cdn.jsdelivr.net/npm/preact@10/dist/preact.umd.js"></script>
<script src="{{ 'countdown-timer.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Countdown Timer",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Block heading",
      "default": "Countdown Timer"
    },
    {
      "type": "text",
      "id": "api_base_url",
      "label": "API Base URL",
      "info": "Your app backend URL e.g. https://your-ngrok-url.ngrok-free.dev",
      "default": "https://your-app-url.ngrok-free.dev"
    },
    {
      "type": "select",
      "id": "position",
      "label": "Widget position",
      "options": [
        { "value": "top", "label": "Top of page" },
        { "value": "bottom", "label": "Bottom of page" },
        { "value": "inline", "label": "Inline" }
      ],
      "default": "inline"
    }
  ]
}
{% endschema %}
